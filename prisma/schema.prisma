generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id           String   @id @default(uuid())
  title        String
  status       String   @default("pending")
  style        String   @default("slideshow")
  duration     Float    @default(3.0)
  transition   String   @default("fade")
  colorEffect  String?
  motionEffect String?
  frameEffect  String?
  textPosition String   @default("bottom")
  captions     String?
  music        String?
  outputPath   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  images       Image[]
}

model Image {
  id          String   @id @default(uuid())
  videoId     String
  filename    String
  originalName String
  path        String
  order       Int
  width       Int
  height      Int
  size        Int
  mimeType    String
  caption     String?
  createdAt   DateTime @default(now())
  
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}
