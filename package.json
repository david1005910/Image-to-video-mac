{
  "name": "image-to-video-mac",
  "version": "1.0.0",
  "description": "이미지를 동영상으로 변환하는 Remotion 기반 앱",
  "scripts": {
    "setup": "npm install && npm run db:setup && npm run dirs",
    "db:setup": "npx prisma generate && npx prisma migrate dev --name init",
    "dirs": "mkdir -p public/uploads public/output",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node src/worker.ts",
    "preview": "remotion preview src/remotion/Root.tsx",
    "start": "concurrently \"npm run dev\" \"npm run worker\""
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "bullmq": "^5.7.0",
    "sharp": "^0.33.0",
    "remotion": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.14.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "concurrently": "^8.2.2"
  }
}
